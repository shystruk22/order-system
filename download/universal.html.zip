<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Универсальный расчёт</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx-js-style@1.2.0/dist/xlsx.bundle.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/lz-string@1.5.0/libs/lz-string.min.js"></script>
    <script src="shared-utils.js"></script>
    <script src="config.js"></script>
    <script src="storage.js"></script>
    <style>
        * { font-family: system-ui, -apple-system, sans-serif; box-sizing: border-box; }
        .btn { transition: all 0.2s; }
        .btn:hover { opacity: 0.9; }
        input:focus, select:focus { outline: none; }
        .input { padding: 0.35rem 0.4rem; border: 1px solid #d1d5db; border-radius: 0.375rem; font-size: 0.75rem; background: white; }
        .input:focus { border-color: #8b5cf6; }
        .table-container { overflow: auto; max-height: 75vh; border-radius: 0.5rem; border: 1px solid #e5e7eb; }
        .table-modern { width: 100%; border-collapse: collapse; font-size: 0.75rem; }
        .table-modern thead { position: sticky; top: 0; z-index: 30; }
        .table-modern th { padding: 0.46rem 0.5rem; text-align: center; font-weight: 600; color: #374151; background: #f3f4f6; border: 1px solid #d1d5db; white-space: nowrap; font-size: 0.7rem; }
        .table-modern th.text-left { text-align: left; }
        .table-modern td { padding: 0.35rem 0.4rem; border: 1px solid #e5e7eb; text-align: center; }
        .table-modern td.text-left { text-align: left; }
        .col-header { min-width: 70px; height: 60px; white-space: normal !important; word-wrap: break-word; line-height: 1.3; vertical-align: middle; padding: 0.5rem 0.4rem !important; font-size: 0.7rem !important; font-weight: 600 !important; text-align: center !important; }
        .col-code { min-width: 45px; max-width: 55px; }
        .col-group { min-width: 70px; max-width: 90px; }
        .col-name { min-width: 160px; }
        .cell-wrap { white-space: normal; word-wrap: break-word; }
        .group-header { background: #e0e7ff; font-weight: 600; color: #3730a3; }
        .store-header { min-height: 60px; max-height: 80px; writing-mode: vertical-rl; text-orientation: mixed; transform: rotate(180deg); font-size: 9px; line-height: 1.2; overflow: hidden; word-wrap: break-word; padding: 4px 2px; }
        .abc-a { background: #dcfce7; color: #166534; }
        .abc-b { background: #fef9c3; color: #854d0e; }
        .abc-c { background: #fee2e2; color: #991b1b; }
    </style>
</head>
<body class="min-h-screen bg-gray-100">
    <div class="bg-white border-b border-gray-200">
        <div class="px-3 py-2">
            <div class="flex items-center gap-2">
                <a href="index.html" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                    <span>Назад</span>
                </a>
                <div class="flex items-center gap-2 px-2">
                    <div class="p-1.5 bg-amber-100 rounded-lg text-amber-600">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                    </div>
                    <h1 class="text-base font-semibold text-gray-900">Универсальный расчёт</h1>
                </div>
                <div class="flex gap-0.5 ml-2 bg-gray-100 rounded-lg p-0.5" id="tabs"></div>
                <div class="ml-auto flex gap-2">
                    <span class="bg-purple-100 text-purple-800 rounded-lg px-2 py-1 text-xs" id="statsProducts">0 тов.</span>
                    <span class="bg-blue-100 text-blue-800 rounded-lg px-2 py-1 text-xs" id="statsStores">0 ТТ</span>
                </div>
            </div>
        </div>
    </div>
    <div class="px-3 py-3" id="content"></div>

    <script>
        let tab = 'upload';
        let matrix = {}; // Ассортимент (каталог): {code, nomenclature, group, packaging, supplier, price, shelf, quant, inPrice, markup}
        let matrixMarks = {}; // Отметки матрицы: {[code]: {[tt]: 'ДА'/'НЕТ', ...}}
        let sales = []; // {tt, name, quantity, group} - продажи С ТТ
        let stocks = []; // {tt, name, code, currentStock, daysPresent, totalDays}
        let stores = []; // [{tt}]
        let period = 21;
        let defaultMarkup = 25;
        
        let searchAssort = '';
        let searchPrices = '';
        let searchResults = '';
        let filterTT = '';
        let filterStatus = '';
        let filterGroup = '';
        let collapsedG = {};
        let collapsedTT = {};
        let groupMarkups = {};

        const KEYS = {
            // Ассортимент (каталог товаров) — теперь отдельно от матрицы
            ASSORTMENT: 'univ_assortment_v1',
            // Отметки матрицы ДА/НЕТ — только marks, без данных товаров
            MATRIX_MARKS: SharedUtils.STORAGE_KEYS.UNIV_MATRIX,   // univ_matrix_v1
            SALES: SharedUtils.STORAGE_KEYS.UNIV_OWN_SALES,       // univ_own_sales_v1
            STOCKS: SharedUtils.STORAGE_KEYS.UNIV_OWN_STOCKS,      // univ_own_stocks_v1
            // Общие
            STORES: SharedUtils.STORAGE_KEYS.STORES,
            DEFAULT_MARKUP: SharedUtils.STORAGE_KEYS.UNIV_DEFAULT_MARKUP,
            GROUP_MARKUPS: SharedUtils.STORAGE_KEYS.UNIV_GROUP_MARKUPS
        };

        const normCode = SharedUtils.normCode;

        const load = (key, def) => SharedUtils.load(key, def);
        const save = (key, data) => SharedUtils.save(key, data);

        // === ЗАГРУЗКА СОХРАНЁННЫХ АССОРТИМЕНТОВ ===
        const ASSORTMENTS_KEY = SharedUtils.STORAGE_KEYS.SAVED_ASSORTMENTS;
        const MATRICES_KEY = SharedUtils.STORAGE_KEYS.SAVED_MATRICES;
        
        function getSavedAssortments() {
            try {
                return SharedUtils.load(ASSORTMENTS_KEY, []);
            } catch { return []; }
        }
        
        function getSavedMatrices() {
            try {
                return SharedUtils.load(MATRICES_KEY, []);
            } catch { return []; }
        }
        
        function loadAssortmentByName(name) {
            const saved = getSavedAssortments();
            const record = saved.find(s => s.name === name);
            
            if (!record) {
                alert('Ассортимент не найден');
                return;
            }
            
            const count = Object.keys(matrix).length;
            if (count > 0) {
                if (!confirm(`Загрузить "${name}" (${record.count} товаров)?\nТекущий ассортимент будет заменен.\nОтметки матрицы (ДА/НЕТ) останутся.`)) {
                    return;
                }
            }
            
            matrix = {};
            record.data.forEach(p => {
                if (p.code) {
                    matrix[normCode(p.code)] = {
                        code: p.code,
                        nomenclature: p.nomenclature || p.name || '',
                        group: p.group || '',
                        packaging: p.packaging || 'ШТ',
                        inPrice: p.price || 0,
                        quant: p.quant || 1,
                        markup: defaultMarkup
                    };
                }
            });
            
            save(KEYS.ASSORTMENT, matrix);
            render();
            alert(`Загружено: ${Object.keys(matrix).length} товаров из "${name}"\nОтметки матрицы: ${Object.keys(matrixMarks).length} товаров`);
        }
        
        // === ЗАГРУЗКА СОХРАНЁННЫХ МАТРИЦ ===
        function loadSavedMatrixByName(name) {
            const saved = getSavedMatrices();
            const record = saved.find(s => s.name === name);
            
            if (!record) {
                alert('Матрица не найден');
                return;
            }
            
            // matrixData: {[code]: {code, nomenclature, group, inMatrix, [tt]: ДА/НЕТ}}
            // MERGE: обновляем ДА/НЕТ по магазинам, каталог — дополняем
            const md = record.matrixData || {};
            let merged = 0;
            let added = 0;
            Object.entries(md).forEach(([code, item]) => {
                if (!code) return;
                const nc = normCode(code);
                
                // Извлекаем ДА/НЕТ marks
                const marks = {};
                Object.entries(item).forEach(([k, v]) => {
                    if (!CATALOG_FIELDS.includes(k) && k !== 'inMatrix' && (v === 'ДА' || v === 'НЕТ')) {
                        marks[k] = v;
                    }
                });
                
                if (Object.keys(marks).length > 0) {
                    if (!matrixMarks[nc]) matrixMarks[nc] = {};
                    Object.assign(matrixMarks[nc], marks);
                }
                
                // Если товара нет в ассортименте — добавляем базовые данные
                if (!matrix[nc]) {
                    matrix[nc] = {
                        code: item.code || code,
                        nomenclature: item.nomenclature || '',
                        group: item.group || '',
                        packaging: 'ШТ',
                        inPrice: 0,
                        quant: 1,
                        markup: defaultMarkup
                    };
                    added++;
                } else {
                    merged++;
                }
            });
            
            save(KEYS.ASSORTMENT, matrix);
            save(KEYS.MATRIX_MARKS, matrixMarks);
            
            const modal = document.getElementById('matrixSelectModal');
            if (modal) modal.remove();
            
            render();
            alert(`Матрица применена: ${merged} обновлено, ${added} добавлено в каталог\nОтметок матрицы: ${Object.keys(matrixMarks).length} товаров\nВсего в ассортименте: ${Object.keys(matrix).length} товаров`);
        }
        
        function showMatrixSelectModal() {
            const saved = getSavedMatrices();
            
            if (saved.length === 0) {
                alert('Нет сохранённых матриц.\nСначала сохраните матрицу в matrix-calc.html');
                return;
            }
            
            const existing = document.getElementById('matrixSelectModal');
            if (existing) existing.remove();
            
            const modal = document.createElement('div');
            modal.id = 'matrixSelectModal';
            modal.className = 'fixed inset-0 bg-black/50 flex items-center justify-center z-50';
            modal.innerHTML = `
                <div class="bg-white rounded-lg border border-gray-200 p-6 w-full max-w-md shadow-lg" onclick="event.stopPropagation()">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-lg font-semibold text-gray-900">${icons.grid} Выберите матрицу</h3>
                        <button onclick="document.getElementById('matrixSelectModal').remove()" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
                    </div>
                    <div class="max-h-80 overflow-y-auto border rounded-lg divide-y">
                        ${saved.map(s => `
                            <div class="p-3 hover:bg-violet-50 cursor-pointer flex justify-between items-center" onclick="loadSavedMatrixByName('${s.name.replace(/'/g, "\\\'")}')">
                                <div>
                                    <div class="font-medium text-gray-900">${s.name}</div>
                                    <div class="text-xs text-gray-500">${s.products || 0} товаров • ${s.inMatrix || 0} в матрице • ${new Date(s.date).toLocaleDateString('ru-RU')}</div>
                                </div>
                                <span class="text-violet-600 font-medium">Загрузить →</span>
                            </div>
                        `).join('')}
                    </div>
                    <div class="mt-4 text-xs text-gray-400 text-center">
                        Матрицы сохраняются в matrix-calc.html
                    </div>
                </div>
            `;
            modal.addEventListener('click', () => modal.remove());
            document.body.appendChild(modal);
        }

        function showAssortmentSelectModal() {
            const saved = getSavedAssortments();
            
            if (saved.length === 0) {
                alert('Нет сохранённых ассортиментов.\nСначала сохраните ассортимент в matrix-calc.html');
                return;
            }
            
            // Закрываем предыдущее модальное окно если есть
            const existing = document.getElementById('assortmentSelectModal');
            if (existing) existing.remove();
            
            const modal = document.createElement('div');
            modal.id = 'assortmentSelectModal';
            modal.className = 'fixed inset-0 bg-black/50 flex items-center justify-center z-50';
            modal.innerHTML = `
                <div class="bg-white rounded-lg border border-gray-200 p-6 w-full max-w-md shadow-lg" onclick="event.stopPropagation()">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-lg font-semibold text-gray-900">${icons.list} Выберите ассортимент</h3>
                        <button onclick="document.getElementById('assortmentSelectModal').remove()" class="text-gray-400 hover:text-gray-600 text-xl">&times;</button>
                    </div>
                    <div class="max-h-80 overflow-y-auto border rounded-lg divide-y">
                        ${saved.map(s => `
                            <div class="p-3 hover:bg-teal-50 cursor-pointer flex justify-between items-center" onclick="loadAssortmentByName('${s.name.replace(/'/g, "\\'")}')">
                                <div>
                                    <div class="font-medium text-gray-900">${s.name}</div>
                                    <div class="text-xs text-gray-500">${s.count} товаров • ${new Date(s.date).toLocaleDateString('ru-RU')}</div>
                                </div>
                                <span class="text-teal-600 font-medium">Загрузить →</span>
                            </div>
                        `).join('')}
                    </div>
                    <div class="mt-4 text-xs text-gray-400 text-center">
                        Ассортименты сохраняются в matrix-calc.html
                    </div>
                </div>
            `;
            modal.addEventListener('click', () => modal.remove());
            document.body.appendChild(modal);
        }

        const icons = {
            upload: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>`,
            list: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/></svg>`,
            grid: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
            dollar: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
            order: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>`,
            download: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
            search: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
            check: `<svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>`,
            x: `<svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`,
            chevronRight: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 18 15 12 9 6"/></svg>`,
            chevronDown: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"/></svg>`,
            trash: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>`,
            db: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
            mapPin: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
            package: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>`,
            sales: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
            stock: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>`,
            supplier: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>`,
            chart: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
            plus: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`,
            save: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>`,
            refresh: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 4 23 10 17 10"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>`,
            import: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
            export: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M16 10l4-4-4-4"/><line x1="20" y1="6" x2="12" y2="6"/><path d="M20 6h-8v12"/></svg>`
        };

        // Поля каталога товаров (не ДА/НЕТ)
        const CATALOG_FIELDS = ['code','nomenclature','name','group','packaging','supplier','quant','price','inPrice','shelf','markup'];

        function init() {
            loadStoresFromHTML();
            sales = load(KEYS.SALES, []);
            stocks = load(KEYS.STOCKS, []);
            defaultMarkup = load(KEYS.DEFAULT_MARKUP, 25);
            groupMarkups = load(KEYS.GROUP_MARKUPS, {});

            // Загрузка с миграцией: старый формат (всё в matrix) → новый (matrix + matrixMarks)
            const savedAssort = load(KEYS.ASSORTMENT, null);
            const savedMarks = load(KEYS.MATRIX_MARKS, null);

            if (savedAssort !== null && savedMarks !== null) {
                // Новый формат — загружаем напрямую
                matrix = savedAssort;
                matrixMarks = savedMarks;
            } else {
                // Старый формат — мигрируем
                const oldData = load('univ_matrix_v1', {});
                if (Object.keys(oldData).length > 0) {
                    console.log('Миграция: разделение matrix на assortment + matrixMarks...');
                    matrix = {};
                    matrixMarks = {};
                    Object.entries(oldData).forEach(([code, item]) => {
                        const catalog = {};
                        CATALOG_FIELDS.forEach(f => {
                            if (item[f] !== undefined && item[f] !== null) catalog[f] = item[f];
                        });
                        if (Object.keys(catalog).length > 0) matrix[code] = catalog;

                        const marks = {};
                        Object.entries(item).forEach(([k, v]) => {
                            if (!CATALOG_FIELDS.includes(k) && (v === 'ДА' || v === 'НЕТ')) {
                                marks[k] = v;
                            }
                        });
                        if (Object.keys(marks).length > 0) matrixMarks[code] = marks;
                    });
                    save(KEYS.ASSORTMENT, matrix);
                    save(KEYS.MATRIX_MARKS, matrixMarks);
                    console.log(`Миграция: ${Object.keys(matrix).length} каталог, ${Object.keys(matrixMarks).length} marks`);
                }
            }
            
            window.addEventListener('storage', (e) => {
                if (e.key === KEYS.STORES) loadStoresFromHTML();
            });
            
            render();
        }

        function loadStoresFromHTML() {
            try {
                const data = SharedUtils.load(KEYS.STORES, []);
                if (Array.isArray(data) && data.length > 0) {
                    stores = data.map(s => ({ tt: s.tt || s.name || s }));
                }
            } catch (e) { console.error('Load stores error:', e); }
        }

        function render() {
            renderTabs();
            renderContent();
            updateStats();
        }

        function updateStats() {
            document.getElementById('statsProducts').textContent = Object.keys(matrix).length + ' тов.';
            document.getElementById('statsStores').textContent = stores.length + ' ТТ';
        }

        function renderTabs() {
            const tabs = [
                { id: 'upload', label: 'Загрузка', icon: icons.upload },
                { id: 'assortment', label: 'Ассортимент', icon: icons.list },
                { id: 'matrix', label: 'Матрица', icon: icons.grid },
                { id: 'prices', label: 'Цены', icon: icons.dollar },
                { id: 'order', label: 'Заказ', icon: icons.order },
            ];
            document.getElementById('tabs').innerHTML = tabs.map(t => `
                <button onclick="tab='${t.id}';render()" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-md transition-colors ${tab === t.id ? 'bg-amber-600 text-white shadow-sm' : 'text-gray-600 hover:bg-white hover:text-gray-900'}">
                    ${t.icon}<span>${t.label}</span>
                </button>
            `).join('');
        }

        function renderContent() {
            const el = document.getElementById('content');
            switch(tab) {
                case 'upload': el.innerHTML = renderUpload(); break;
                case 'assortment': el.innerHTML = renderAssortment(); break;
                case 'matrix': el.innerHTML = renderMatrix(); break;
                case 'prices': el.innerHTML = renderPrices(); break;
                case 'order': el.innerHTML = renderOrder(); break;
            }
        }

        function renderUpload() {
            // Получаем сохранённые ассортименты из matrix-calc
            const savedAssortments = getSavedAssortments();
            const savedMatrices = getSavedMatrices();
            
            return `
                <div class="space-y-2">
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-2">
                        <div onclick="document.getElementById('salesInput').click()" class="bg-white rounded-lg border border-gray-200 p-4 cursor-pointer hover:border-gray-400 transition-colors">
                            <div class="flex flex-col items-center text-center">
                                <div class="p-3 bg-emerald-50 rounded-lg text-emerald-600 mb-3">${icons.sales}</div>
                                <h3 class="font-medium text-gray-800 mb-1">Продажи</h3>
                                <p class="text-xs text-gray-400">ТТ → Кат → Гр → Товар</p>
                                <input type="file" id="salesInput" accept=".xlsx,.xls,.csv" onchange="handleFile(this, 'sales')" class="hidden">
                                ${sales.length > 0 ? `<p class="mt-2 text-sm text-emerald-600 font-medium">${sales.length} записей</p>` : ''}
                            </div>
                        </div>
                        <div onclick="document.getElementById('stocksInput').click()" class="bg-white rounded-lg border border-gray-200 p-4 cursor-pointer hover:border-gray-400 transition-colors">
                            <div class="flex flex-col items-center text-center">
                                <div class="p-3 bg-sky-50 rounded-lg text-sky-600 mb-3">${icons.stock}</div>
                                <h3 class="font-medium text-gray-800 mb-1">Остатки на ТТ</h3>
                                <p class="text-xs text-gray-400">ТТ | Наим | Код | Ост.</p>
                                <input type="file" id="stocksInput" accept=".xlsx,.xls,.csv" onchange="handleFile(this, 'stocks')" class="hidden">
                                ${stocks.length > 0 ? `<p class="mt-2 text-sm text-sky-600 font-medium">${stocks.length} записей</p>` : ''}
                            </div>
                        </div>
                        <div class="bg-white rounded-lg border border-gray-200 p-4">
                            <div class="flex flex-col items-center text-center">
                                <div class="p-3 bg-violet-50 rounded-lg text-violet-600 mb-3">${icons.grid}</div>
                                <h3 class="font-medium text-gray-800 mb-1">Матрица</h3>
                                <p class="text-xs text-gray-400 mb-2">Товары → ДА/НЕТ по ТТ</p>
                                <div class="flex gap-1 w-full">
                                    <button onclick="document.getElementById('matrixInput').click()" class="flex-1 px-2 py-1.5 text-xs font-medium text-violet-700 bg-violet-50 border border-violet-200 rounded hover:bg-violet-100">
                                        ${icons.upload} Файл
                                    </button>
                                    ${savedMatrices.length > 0 ? `
                                    <button onclick="showMatrixSelectModal()" class="flex-1 px-2 py-1.5 text-xs font-medium text-teal-700 bg-teal-50 border border-teal-200 rounded hover:bg-teal-100">
                                        ${icons.list} Из списка
                                    </button>
                                    ` : ''}
                                </div>
                                <input type="file" id="matrixInput" accept=".xlsx,.xls" onchange="importMatrix(this)" class="hidden">
                                ${Object.keys(matrixMarks).length > 0 ? `<p class="mt-2 text-sm text-violet-600 font-medium">${Object.keys(matrixMarks).length} тов.</p>` : ''}
                            </div>
                        </div>
                        <div class="bg-white rounded-lg border border-gray-200 p-4">
                            <div class="flex flex-col items-center text-center">
                                <div class="p-3 bg-amber-50 rounded-lg text-amber-600 mb-3">${icons.package}</div>
                                <h3 class="font-medium text-gray-800 mb-1">Ассортимент</h3>
                                <p class="text-xs text-gray-400 mb-2">Группа | Наим | Код | Цена</p>
                                <div class="flex gap-1 w-full">
                                    <button onclick="document.getElementById('assortInput').click()" class="flex-1 px-2 py-1.5 text-xs font-medium text-amber-700 bg-amber-50 border border-amber-200 rounded hover:bg-amber-100">
                                        ${icons.upload} Файл
                                    </button>
                                    ${savedAssortments.length > 0 ? `
                                    <button onclick="showAssortmentSelectModal()" class="flex-1 px-2 py-1.5 text-xs font-medium text-teal-700 bg-teal-50 border border-teal-200 rounded hover:bg-teal-100">
                                        ${icons.list} Из списка
                                    </button>
                                    ` : ''}
                                </div>
                                <input type="file" id="assortInput" accept=".xlsx,.xls" onchange="importAssortment(this)" class="hidden">
                                ${Object.keys(matrix).length > 0 ? `<p class="mt-2 text-sm text-amber-600 font-medium">${Object.keys(matrix).length} тов.</p>` : ''}
                            </div>
                        </div>
                    </div>
                    
                    ${savedAssortments.length > 0 ? `
                    <div class="bg-teal-50 rounded-lg border border-teal-200 p-2">
                        <div class="flex items-center gap-2 text-xs text-teal-700">
                            <span>${icons.save} Сохранённые ассортименты:</span>
                            ${savedAssortments.slice(0, 3).map(s => `
                                <button onclick="loadAssortmentByName('${s.name.replace(/'/g, "\\'")}')" class="px-2 py-1 bg-white border border-teal-300 rounded hover:bg-teal-100">
                                    ${s.name} (${s.count})
                                </button>
                            `).join('')}
                            ${savedAssortments.length > 3 ? `<button onclick="showAssortmentSelectModal()" class="px-2 py-1 text-teal-600 hover:underline">ещё ${savedAssortments.length - 3}...</button>` : ''}
                        </div>
                    </div>
                    ` : ''}
                    
                    ${savedMatrices.length > 0 ? `
                    <div class="bg-violet-50 rounded-lg border border-violet-200 p-2">
                        <div class="flex items-center gap-2 text-xs text-violet-700">
                            <span>${icons.grid} Сохранённые матрицы:</span>
                            ${savedMatrices.slice(0, 3).map(s => `
                                <button onclick="loadSavedMatrixByName('${s.name.replace(/'/g, "\\'")}')" class="px-2 py-1 bg-white border border-violet-300 rounded hover:bg-violet-100">
                                    ${s.name} (${s.products || 0})
                                </button>
                            `).join('')}
                            ${savedMatrices.length > 3 ? `<button onclick="showMatrixSelectModal()" class="px-2 py-1 text-violet-600 hover:underline">ещё ${savedMatrices.length - 3}...</button>` : ''}
                        </div>
                    </div>
                    ` : ''}
                    
                    <div class="bg-white rounded-lg border border-gray-200 p-3">
                        <div class="flex flex-wrap items-center gap-3">
                            <div class="flex items-center gap-2 bg-gray-50 px-3 py-2 rounded-md border border-gray-200">
                                <label class="text-sm text-gray-600">Период:</label>
                                <input type="number" value="${period}" onchange="period=parseInt(this.value)||21" class="input w-14 text-center" min="1" max="60">
                                <span class="text-sm text-gray-500">дней</span>
                            </div>
                            <div class="flex items-center gap-2 bg-gray-50 px-3 py-2 rounded-md border border-gray-200">
                                <label class="text-sm text-gray-600">Наценка:</label>
                                <input type="number" value="${defaultMarkup}" onchange="defaultMarkup=parseFloat(this.value)||25;save(KEYS.DEFAULT_MARKUP,defaultMarkup)" class="input w-14 text-center" step="0.1">
                                <span class="text-sm text-gray-500">%</span>
                            </div>
                            <span class="bg-orange-100 px-2 py-1 rounded-md text-xs text-orange-700">ТТ: ${stores.length}</span>
                            <button onclick="if(confirm('Очистить все данные?'))clearAll()" class="btn px-3 py-1.5 text-sm font-medium text-red-600 bg-white border border-red-300 rounded-md hover:bg-red-50 ml-auto">${icons.trash}<span>Сброс</span></button>
                        </div>
                    </div>
                </div>`;
        }


        function getAllGroups() {
            const groups = new Set();
            Object.values(matrix).forEach(p => { if (p.group) groups.add(p.group); });
            return Array.from(groups).sort((a, b) => a.localeCompare(b, 'ru'));
        }

        function renderAssortment() {
            const totalItems = Object.keys(matrix).length;
            const allGroups = getAllGroups();
            
            let html = `<div class="bg-white rounded-lg border border-gray-200 p-3 mb-3">
                <div class="flex justify-between items-center">
                    <div class="flex gap-2 items-center">
                        <div class="bg-amber-100 text-amber-800 rounded-lg px-3 py-1.5">
                            <span class="text-xs">Товаров: </span><strong>${totalItems}</strong>
                        </div>
                        <div class="bg-blue-100 text-blue-800 rounded-lg px-3 py-1.5">
                            <span class="text-xs">Групп: </span><strong>${allGroups.length}</strong>
                        </div>
                        <div class="relative">
                            <input type="text" placeholder="Поиск по названию или коду..." value="${searchAssort}" oninput="searchAssort=this.value;render()" class="pl-8 pr-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:outline-none focus:border-amber-400 w-56">
                            <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400">${icons.search}</span>
                            ${searchAssort ? `<button onclick="searchAssort='';render()" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">✕</button>` : ''}
                        </div>
                        <select onchange="filterGroup=this.value;render()" class="px-2 py-1.5 text-sm border border-gray-300 rounded-lg focus:outline-none focus:border-amber-400">
                            <option value="">Все группы</option>
                            ${allGroups.map(g => `<option value="${g}" ${filterGroup === g ? 'selected' : ''}>${g}</option>`).join('')}
                        </select>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="showAddProductModal()" class="btn inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700">${icons.plus} Добавить</button>
                        <button onclick="exportAssortment()" class="btn inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700">${icons.export} Экспорт</button>
                    </div>
                </div>
            </div>`;

            if (totalItems === 0) {
                html += `<div class="text-center py-12">${icons.db}<p class="text-gray-500 mt-3">Загрузите данные</p></div>`;
            } else {
                const grouped = {};
                Object.entries(matrix).forEach(([code, p]) => {
                    if (searchAssort && !p.nomenclature?.toLowerCase().includes(searchAssort.toLowerCase()) && !code.includes(searchAssort)) return;
                    if (filterGroup && p.group !== filterGroup) return;
                    const gr = p.group || 'Без группы';
                    if (!grouped[gr]) grouped[gr] = [];
                    grouped[gr].push({ code, ...p });
                });

                Object.keys(grouped).forEach(gr => {
                    grouped[gr].sort((a, b) => (a.nomenclature || '').localeCompare(b.nomenclature || '', 'ru'));
                });

                html += `<div class="table-container">
                    <table class="table-modern">
                        <thead>
                            <tr>
                                <th class="text-left">Группа</th>
                                <th class="text-left">Наименование</th>
                                <th class="text-left">Код</th>
                                <th class="text-center">Упак.</th>
                                <th class="text-left">Поставщик</th>
                                <th class="text-right">Цена</th>
                                <th class="text-right">Полка</th>
                                <th class="text-center">Квант</th>
                                <th class="text-center w-10"></th>
                            </tr>
                        </thead>
                        <tbody>
                            ${Object.entries(grouped).sort((a,b) => a[0].localeCompare(b[0], 'ru')).map(([gr, items]) => `
                                <tr class="bg-amber-50 cursor-pointer hover:bg-amber-100" onclick="collapsedG['${gr}']=!collapsedG['${gr}'];render()">
                                    <td colspan="9" class="font-semibold text-amber-800">
                                        <span class="flex items-center gap-2">${collapsedG[gr] ? icons.chevronRight : icons.chevronDown}${gr} (${items.length})</span>
                                    </td>
                                </tr>
                                ${collapsedG[gr] ? '' : items.map(p => `
                                    <tr class="hover:bg-gray-50">
                                        <td class="text-xs"><input type="text" value="${p.group || ''}" onchange="updateProduct('${p.code}', 'group', this.value)" class="input w-32 text-xs" placeholder="Группа"></td>
                                        <td class="font-medium text-gray-700 text-left">${p.nomenclature || ''}</td>
                                        <td class="font-mono text-xs text-gray-600">${p.code}</td>
                                        <td class="text-center text-gray-500">${p.packaging || 'ШТ'}</td>
                                        <td class="text-xs"><input type="text" value="${p.supplier || ''}" onchange="updateProduct('${p.code}', 'supplier', this.value)" class="input w-24 text-xs" placeholder="Поставщик"></td>
                                        <td class="text-right"><input type="number" step="0.01" value="${p.price || 0}" onchange="updateProduct('${p.code}', 'price', parseFloat(this.value)||0)" class="input w-16 text-right text-xs"></td>
                                        <td class="text-right"><input type="number" step="0.01" value="${p.shelf || 0}" onchange="updateProduct('${p.code}', 'shelf', parseFloat(this.value)||0)" class="input w-16 text-right text-xs"></td>
                                        <td class="text-center"><input type="number" value="${p.quant || 1}" onchange="updateProduct('${p.code}', 'quant', parseFloat(this.value)||1)" class="input w-12 text-center text-xs" step="1"></td>
                                        <td class="text-center"><button onclick="event.stopPropagation();deleteProduct('${p.code}')" class="text-red-500 hover:text-red-700 p-1">${icons.trash}</button></td>
                                    </tr>
                                `).join('')}
                            `).join('')}
                        </tbody>
                    </table>
                </div>`;
            }
            
            html += `</div>
            <div id="addProductModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
                <div class="bg-white rounded-lg p-6 w-96 max-w-full mx-4">
                    <h3 class="text-lg font-semibold mb-4">Добавить товар</h3>
                    <div class="space-y-3">
                        <input type="text" id="newProductName" placeholder="Наименование *" class="input w-full">
                        <input type="text" id="newProductCode" placeholder="Код *" class="input w-full">
                        <input type="text" id="newProductGroup" placeholder="Группа" class="input w-full">
                        <div class="flex gap-2">
                            <input type="text" id="newProductPackaging" placeholder="Упак" value="ШТ" class="input w-20">
                            <input type="number" id="newProductQuant" placeholder="Квант" value="1" class="input w-20">
                            <input type="number" id="newProductPrice" placeholder="Вх. цена" class="input flex-1">
                        </div>
                    </div>
                    <div class="flex justify-end gap-2 mt-4">
                        <button onclick="hideAddProductModal()" class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg">Отмена</button>
                        <button onclick="addNewProduct()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Добавить</button>
                    </div>
                </div>
            </div>`;
            
            return html;
        }

        function updateProduct(code, field, value) {
            if (matrix[code]) {
                matrix[code][field] = value;
                save(KEYS.ASSORTMENT, matrix);
                if (['inPrice', 'markup', 'group'].includes(field)) render();
            }
        }

        function deleteProduct(code) {
            if (confirm(`Удалить "${matrix[code]?.nomenclature || code}"?`)) {
                delete matrix[code];
                delete matrixMarks[code];
                save(KEYS.ASSORTMENT, matrix);
                save(KEYS.MATRIX_MARKS, matrixMarks);
                render();
            }
        }

        function showAddProductModal() {
            document.getElementById('addProductModal').classList.remove('hidden');
            document.getElementById('addProductModal').classList.add('flex');
            document.getElementById('newProductName').focus();
        }

        function hideAddProductModal() {
            document.getElementById('addProductModal').classList.add('hidden');
            document.getElementById('addProductModal').classList.remove('flex');
        }

        function addNewProduct() {
            const name = document.getElementById('newProductName').value.trim();
            const code = document.getElementById('newProductCode').value.trim();
            if (!name || !code) { alert('Введите наименование и код'); return; }
            const normC = normCode(code);
            if (matrix[normC]) { alert('Товар уже существует'); return; }
            matrix[normC] = {
                nomenclature: name, code: normC,
                group: document.getElementById('newProductGroup').value.trim(),
                packaging: document.getElementById('newProductPackaging').value.trim() || 'ШТ',
                quant: parseFloat(document.getElementById('newProductQuant').value) || 1,
                inPrice: parseFloat(document.getElementById('newProductPrice').value) || 0
            };
            save(KEYS.ASSORTMENT, matrix);
            hideAddProductModal();
            render();
        }

        function importAssortment(input) {
            const file = input.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const data = new Uint8Array(e.target.result);
                    const wb = XLSX.read(data, { type: 'array' });
                    const json = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], { header: 1, defval: '' });
                    const { items } = SharedUtils.parseAssortment(json);
                    
                    let count = 0;
                    items.forEach(p => {
                        if (p.code) {
                            matrix[p.code] = {
                                nomenclature: p.nomenclature || '',
                                code: p.code,
                                group: p.group || '',
                                packaging: p.packaging || 'ШТ',
                                supplier: p.supplier || '',
                                quant: p.quant || 1,
                                price: p.price || 0,
                                inPrice: p.inPrice || 0,
                                shelf: p.shelf || 0,
                                markup: defaultMarkup
                            };
                            count++;
                        }
                    });
                    
                    save(KEYS.ASSORTMENT, matrix);
                    render();
                    alert(`Импортировано ${count} товаров в ассортимент
Отметки матрицы не затронуты (${Object.keys(matrixMarks).length} товаров)`);
                } catch (err) { alert('Ошибка: ' + err.message); }
            };
            reader.readAsArrayBuffer(file);
            input.value = '';
        }

        function exportAssortment() {
            const rows = [['Группа', 'Наименование', 'Код', 'Упаковка', 'Поставщик', 'Цена', 'Полка', 'Квант']];
            Object.values(matrix).forEach(p => rows.push([p.group || '', p.nomenclature || '', p.code, p.packaging || 'ШТ', p.supplier || '', p.price || 0, p.shelf || 0, p.quant || 1]));
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(rows), 'Ассортимент');
            XLSX.writeFile(wb, 'assortment.xlsx');
        }

        function renderMatrix() {
            if (Object.keys(matrix).length === 0) return `<div class="bg-white rounded-lg border border-gray-200 p-4"><div class="text-center py-12">${icons.db}<p class="text-gray-500 mt-3">Загрузите данные</p></div></div>`;

            // Группировка по группам из ассортимента
            const grouped = {};
            Object.entries(matrix).forEach(([code, p]) => {
                const gr = p.group || 'Без группы';
                if (!grouped[gr]) grouped[gr] = [];
                grouped[gr].push({ code, ...p });
            });

            return `<div class="bg-white rounded-lg border border-gray-200 p-3 mb-3">
                <div class="flex justify-between items-center">
                    <div class="flex gap-2 items-center">
                        <div class="bg-amber-100 text-amber-800 rounded-lg px-3 py-1.5">
                            <span class="text-xs">Товаров: </span><strong>${Object.keys(matrix).length}</strong>
                        </div>
                        <div class="bg-violet-100 text-violet-800 rounded-lg px-3 py-1.5">
                            <span class="text-xs">В матрице: </span><strong>${Object.keys(matrixMarks).length}</strong>
                        </div>
                        <div class="bg-blue-100 text-blue-800 rounded-lg px-3 py-1.5">
                            <span class="text-xs">Магазинов: </span><strong>${stores.length}</strong>
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="document.getElementById('matrixImportInput').click()" class="btn inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700">${icons.import} Импорт</button>
                        <input type="file" id="matrixImportInput" accept=".xlsx,.xls" onchange="importMatrix(this)" class="hidden">
                        <button onclick="exportMatrix()" class="btn inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700">${icons.export} Экспорт</button>
                    </div>
                </div>
            </div>
            
            <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
                <div class="text-xs text-gray-500 p-2">Клик для переключения ДА/НЕТ • <span class="text-violet-600">Фиолетовый = в матрице</span> • <span class="text-gray-400">Пустой = вне матрицы</span></div>
                <div class="table-container">
                    <table class="table-modern">
                        <thead>
                            <tr>
                                <th class="text-left sticky left-0 bg-gray-50 z-20" style="min-width:80px">Группа</th>
                                <th class="text-left" style="min-width:150px">Наименование</th>
                                <th class="text-left">Код</th>
                                ${stores.map(s => `<th class="text-center min-w-[70px]"><div class="store-header" title="${s.tt}">${s.tt}</div></th>`).join('')}
                                <th class="text-center w-10"></th>
                            </tr>
                        </thead>
                        <tbody>
                            ${Object.entries(grouped).sort((a,b) => a[0].localeCompare(b[0], 'ru')).map(([gr, items]) => `
                                <tr class="group-header cursor-pointer" onclick="collapsedG['matrix_${gr}']=!collapsedG['matrix_${gr}'];render()">
                                    <td colspan="${3 + stores.length}" class="text-left py-1 px-2">
                                        <div class="flex items-center gap-2">
                                            ${collapsedG['matrix_' + gr] ? icons.chevronRight : icons.chevronDown}
                                            <span class="font-semibold">${gr}</span>
                                            <span class="text-[10px] bg-indigo-200 text-indigo-800 px-1 rounded">${items.length}</span>
                                        </div>
                                    </td>
                                </tr>
                                ${collapsedG['matrix_' + gr] ? '' : items.map(p => {
                                    const inMatrix = !!matrixMarks[p.code];
                                    return `
                                    <tr class="hover:bg-gray-50 ${inMatrix ? '' : 'opacity-60'}">
                                        <td class="text-left text-[10px] sticky left-0 bg-white z-10">${p.group || ''}</td>
                                        <td class="text-left font-medium text-xs">${p.nomenclature || ''}</td>
                                        <td class="font-mono text-[10px]">${p.code}</td>
                                        ${stores.map(s => {
                                            const mark = matrixMarks[p.code] ? matrixMarks[p.code][s.tt] : null;
                                            const isYes = mark === 'ДА';
                                            const isNo = mark === 'НЕТ';
                                            return `<td class="text-center cursor-pointer font-medium select-none ${isYes ? 'bg-emerald-100 text-emerald-800 hover:bg-emerald-200' : isNo ? 'bg-rose-50 text-rose-600 hover:bg-rose-100' : 'bg-gray-50 text-gray-300 hover:bg-gray-100'}" onclick="toggleMatrixCell('${p.code}', '${s.tt}')">
                                                ${isYes ? icons.check : ''}
                                            </td>`;
                                        }).join('')}
                                        <td class="text-center"><button onclick="event.stopPropagation();deleteFromMatrix('${p.code}')" class="text-red-500 hover:text-red-700 p-1">${icons.trash}</button></td>
                                    </tr>`;
                                }).join('')}
                            `).join('')}
                        </tbody>
                    </table>
                </div>
            </div>`;
        }

        function toggleMatrixCell(code, tt) {
            if (!matrixMarks[code]) matrixMarks[code] = {};
            matrixMarks[code][tt] = matrixMarks[code][tt] === 'ДА' ? 'НЕТ' : 'ДА';
            save(KEYS.MATRIX_MARKS, matrixMarks);
            render();
        }

        function deleteFromMatrix(code) {
            if (confirm(`Удалить "${matrix[code]?.nomenclature || code}"?`)) {
                delete matrix[code];
                delete matrixMarks[code];
                save(KEYS.ASSORTMENT, matrix);
                save(KEYS.MATRIX_MARKS, matrixMarks);
                render();
            }
        }

        function importMatrix(input) {
            const file = input.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const data = new Uint8Array(e.target.result);
                    const wb = XLSX.read(data, { type: 'array' });
                    const json = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], { defval: '' });
                    const headers = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], { header: 1 })[0] || [];
                    
                    json.forEach(row => {
                        const code = normCode(String(row['Код'] || ''));
                        if (!code) return;
                        
                        // Добавляем в ассортимент если нет
                        if (!matrix[code]) {
                            matrix[code] = { nomenclature: String(row['Наименование'] || '').trim(), code, group: String(row['Группа'] || '').trim() };
                        } else {
                            // Обновляем группу если пустая
                            if (!matrix[code].group) matrix[code].group = String(row['Группа'] || '').trim();
                            if (!matrix[code].nomenclature) matrix[code].nomenclature = String(row['Наименование'] || '').trim();
                        }
                        
                        // Извлекаем ДА/НЕТ marks в matrixMarks
                        if (!matrixMarks[code]) matrixMarks[code] = {};
                        headers.forEach((h, i) => {
                            if (i > 2 && h) {
                                const ttName = String(h).trim();
                                if (stores.some(s => s.tt === ttName)) {
                                    const val = String(row[ttName] || Object.values(row)[i] || '').toUpperCase();
                                    matrixMarks[code][ttName] = val === 'ДА' || val === 'YES' || val === '1' ? 'ДА' : 'НЕТ';
                                }
                            }
                        });
                    });
                    save(KEYS.ASSORTMENT, matrix);
                    save(KEYS.MATRIX_MARKS, matrixMarks);
                    render();
                    alert(`Ассортимент: ${Object.keys(matrix).length} товаров\nОтметки матрицы: ${Object.keys(matrixMarks).length} товаров`);
                } catch (err) { alert('Ошибка: ' + err.message); }
            };
            reader.readAsArrayBuffer(file);
            input.value = '';
        }

        function exportMatrix() {
            if (Object.keys(matrix).length === 0) { alert('Нет данных'); return; }
            const headers = ['Группа', 'Наименование', 'Код', ...stores.map(s => s.tt)];
            const rows = [headers];
            Object.entries(matrix).forEach(([code, p]) => {
                const row = [p.group || '', p.nomenclature || '', code];
                stores.forEach(s => row.push((matrixMarks[code] && matrixMarks[code][s.tt] === 'ДА') ? 'ДА' : 'НЕТ'));
                rows.push(row);
            });
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(rows), 'Матрица');
            XLSX.writeFile(wb, 'matrix.xlsx');
        }

        function renderPrices() {
            const allGroups = getAllGroups();
            let totalRevenue = 0, totalProfit = 0, totalPurchase = 0;
            
            sales.forEach(s => {
                const product = Object.values(matrix).find(p => p.nomenclature === s.name);
                if (product) {
                    const inPrice = product.inPrice || 0;
                    const markup = product.markup ?? groupMarkups[product.group || ''] ?? defaultMarkup;
                    const shelfPrice = inPrice * (1 + markup / 100);
                    totalPurchase += s.quantity * inPrice;
                    totalRevenue += s.quantity * shelfPrice;
                    totalProfit += s.quantity * (shelfPrice - inPrice);
                }
            });

            const individualMarkups = Object.values(matrix).filter(p => p.markup !== undefined && p.markup !== null).length;
            
            return `<div class="space-y-3">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div class="bg-gradient-to-r from-violet-50 to-indigo-50 rounded-lg border border-violet-200 p-4">
                        <div class="flex items-center gap-2 mb-3">${icons.chart}<h2 class="text-sm font-semibold text-violet-800">Доходность</h2></div>
                        <div class="grid grid-cols-2 gap-2">
                            <div class="bg-white rounded-lg p-2 border border-violet-100 text-center"><div class="text-[10px] text-gray-500">Закупка</div><div class="text-base font-bold text-gray-800">${totalPurchase.toLocaleString('ru-RU')} ₽</div></div>
                            <div class="bg-white rounded-lg p-2 border border-violet-100 text-center"><div class="text-[10px] text-gray-500">Выручка</div><div class="text-base font-bold text-gray-800">${totalRevenue.toLocaleString('ru-RU')} ₽</div></div>
                            <div class="bg-white rounded-lg p-2 border border-violet-100 text-center"><div class="text-[10px] text-gray-500">Прибыль</div><div class="text-base font-bold text-emerald-600">${totalProfit.toLocaleString('ru-RU')} ₽</div></div>
                            <div class="bg-white rounded-lg p-2 border border-violet-100 text-center"><div class="text-[10px] text-gray-500">Маржа</div><div class="text-base font-bold text-violet-600">${totalPurchase > 0 ? ((totalProfit / totalPurchase) * 100).toFixed(1) : 0}%</div></div>
                        </div>
                    </div>
                    
                    <div class="bg-white rounded-lg border border-gray-200 p-4">
                        <h3 class="text-sm font-semibold text-gray-800 mb-3 flex items-center gap-2">${icons.dollar}Настройки наценок</h3>
                        <div class="flex gap-3">
                            <div class="flex-1 flex items-center justify-between bg-gray-50 px-3 py-2 rounded-lg border">
                                <label class="text-sm text-gray-600">По умолчанию:</label>
                                <div class="flex items-center gap-1">
                                    <input type="number" value="${defaultMarkup}" onchange="defaultMarkup=parseFloat(this.value)||25;save(KEYS.DEFAULT_MARKUP,defaultMarkup);render()" class="input w-16 text-center text-sm font-bold text-blue-700" step="0.1">
                                    <span class="text-sm text-gray-500">%</span>
                                </div>
                            </div>
                            <div class="bg-blue-50 px-3 py-2 rounded-lg border border-blue-200 text-center">
                                <div class="text-[10px] text-gray-500">Индивид.</div>
                                <div class="text-lg font-bold text-blue-700">${individualMarkups}</div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="bg-white rounded-lg border border-gray-200 p-4">
                    <h3 class="text-sm font-semibold text-gray-800 mb-3">Наценки по категориям</h3>
                    <div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-2 max-h-[200px] overflow-auto">
                        ${allGroups.map(group => {
                            const markup = groupMarkups[group] ?? '';
                            return `<div class="bg-gray-50 rounded px-2 py-2 text-xs border">
                                <div class="font-medium text-gray-700 break-words leading-tight" style="min-height: 32px; word-break: break-word;">${group}</div>
                                <div class="flex items-center gap-1 mt-1">
                                    <input type="number" value="${markup}" onchange="updateGroupMarkup('${group}', this.value)" placeholder="${defaultMarkup}" class="input w-14 text-center text-xs font-bold py-0.5" step="0.1">
                                    <span class="text-gray-400 text-[10px]">%</span>
                                </div>
                            </div>`;
                        }).join('')}
                    </div>
                </div>
                
                <div class="bg-white rounded-lg border border-gray-200 p-3">
                    <div class="flex justify-between items-center mb-3">
                        <h2 class="text-sm font-semibold text-gray-800 flex items-center gap-2">${icons.dollar}Цены по товарам</h2>
                        <div class="flex gap-2">
                            <input type="text" placeholder="Поиск..." value="${searchPrices}" oninput="searchPrices=this.value;render()" class="input w-40">
                            <button onclick="exportPrices()" class="btn px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">${icons.download}</button>
                        </div>
                    </div>
                    <div class="table-container">
                        <table class="table-modern">
                            <thead>
                                <tr>
                                    <th class="text-left">Наименование</th>
                                    <th class="text-center">Группа</th>
                                    <th class="text-center">Вход. цена</th>
                                    <th class="text-center bg-green-100">Полка ₽</th>
                                    <th class="text-center bg-orange-100">Наценка %</th>
                                    <th class="text-center">Доход ₽</th>
                                    <th class="text-center">Доход %</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${Object.entries(matrix).filter(([code, p]) => {
                                    if (!searchPrices) return true;
                                    return p.nomenclature?.toLowerCase().includes(searchPrices.toLowerCase()) || code.includes(searchPrices);
                                }).map(([code, p]) => {
                                    const inPrice = p.inPrice || 0;
                                    const markup = p.markup ?? groupMarkups[p.group || ''] ?? defaultMarkup;
                                    const shelfPrice = Math.round(inPrice * (1 + markup / 100));
                                    const profit = shelfPrice - inPrice;
                                    const profitPercent = inPrice > 0 ? ((profit / inPrice) * 100).toFixed(1) : 0;
                                    const hasIndividual = p.markup !== undefined && p.markup !== null;
                                    return `
                                        <tr class="hover:bg-gray-50">
                                            <td class="text-left font-medium text-gray-700">${p.nomenclature || ''}</td>
                                            <td class="text-center text-xs text-gray-500">${p.group || ''}</td>
                                            <td class="text-center"><input type="number" value="${inPrice}" onchange="updateProduct('${code}', 'inPrice', parseFloat(this.value)||0)" class="input w-20 text-center text-xs"></td>
                                            <td class="text-center font-semibold bg-green-50">${shelfPrice.toLocaleString('ru-RU')} ₽</td>
                                            <td class="text-center bg-orange-50"><input type="number" value="${hasIndividual ? p.markup : ''}" onchange="updateProductMarkup('${code}', this.value)" placeholder="${groupMarkups[p.group || ''] ?? defaultMarkup}" class="input w-14 text-center text-xs font-bold ${hasIndividual ? 'text-blue-700' : ''}"></td>
                                            <td class="text-center font-medium ${profit > 0 ? 'text-emerald-600' : 'text-gray-500'}">${profit.toLocaleString('ru-RU')} ₽</td>
                                            <td class="text-center font-medium ${profit > 0 ? 'text-emerald-600' : 'text-gray-500'}">${profitPercent}%</td>
                                        </tr>`;
                                }).join('')}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>`;
        }

        function updateGroupMarkup(group, value) {
            if (value === '' || value === null) delete groupMarkups[group];
            else groupMarkups[group] = parseFloat(value) || 0;
            save(KEYS.GROUP_MARKUPS, groupMarkups);
            render();
        }

        function updateProductMarkup(code, value) {
            if (matrix[code]) {
                if (value === '' || value === null) delete matrix[code].markup;
                else matrix[code].markup = parseFloat(value) || 0;
                save(KEYS.ASSORTMENT, matrix);
                render();
            }
        }

        function exportPrices() {
            const rows = [['Группа', 'Наименование', 'Код', 'Вход. цена', 'Наценка %', 'Полка', 'Доход ₽', 'Доход %']];
            Object.entries(matrix).forEach(([code, p]) => {
                const inPrice = p.inPrice || 0;
                const markup = p.markup ?? groupMarkups[p.group || ''] ?? defaultMarkup;
                const shelfPrice = Math.round(inPrice * (1 + markup / 100));
                const profit = shelfPrice - inPrice;
                rows.push([p.group || '', p.nomenclature || '', code, inPrice, markup, shelfPrice, profit, inPrice > 0 ? ((profit / inPrice) * 100).toFixed(1) + '%' : '0%']);
            });
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(rows), 'Цены');
            XLSX.writeFile(wb, 'prices.xlsx');
        }

        // === ЗАКАЗ ===
        function calcOrder(stock, avgDay, periodDays, quant) {
            const prelimOrder = avgDay * periodDays;
            const order = stock - prelimOrder;
            if (order > 6) return 0;
            if (order < 0) {
                const need = Math.abs(order);
                return Math.ceil(need / quant) * quant;
            }
            if (order >= 0 && order <= 6) {
                const need = Math.max(1, order);
                return Math.ceil(need / quant) * quant;
            }
            return 0;
        }

        function renderOrder() {
            if (Object.keys(matrix).length === 0) return `<div class="bg-white rounded-lg border border-gray-200 p-4"><div class="text-center py-12">${icons.db}<p class="text-gray-500 mt-3">Загрузите данные</p></div></div>`;
            if (stores.length === 0) return `<div class="bg-white rounded-lg border border-gray-200 p-4"><div class="text-center py-12">${icons.db}<p class="text-gray-500 mt-3">Загрузите магазины</p></div></div>`;

            // Карта остатков по ТТ и коду
            const stockMap = new Map();
            stocks.forEach(s => stockMap.set(`${s.tt}_${s.code}`, s));

            // Карта продаж по ТТ и коду (ключ = ТТ_КОД)
            const salesByTTCode = {};
            sales.forEach(s => {
                const product = Object.values(matrix).find(p => p.nomenclature === s.name);
                if (product && s.tt) {
                    const key = `${s.tt}_${product.code}`;
                    salesByTTCode[key] = (salesByTTCode[key] || 0) + s.quantity;
                }
            });

            const results = [];
            stores.forEach(store => {
                Object.entries(matrix).forEach(([code, p]) => {
                    const key = `${store.tt}_${code}`;
                    const stockData = stockMap.get(key);

                    // Нет остатков — пропускаем (если нет в матрице с ДА)
                    const codeInMatrix = !!matrixMarks[code];
                    const markForTT = codeInMatrix ? (matrixMarks[code][store.tt] || 'НЕТ') : null;
                    const matrixDA = markForTT === 'ДА';

                    if (!stockData) {
                        // Нет остатков — показываем только если в матрице ДА
                        if (matrixDA) {
                            results.push({ tt: store.tt, code, nomenclature: p.nomenclature || '', group: p.group || '', currentStock: 0, sales: salesByTTCode[key] || 0, daysPresent: 0, avgSalesPerDay: 0, order: 0, quant: p.quant || 1, inPrice: p.inPrice || 0, sum: 0, status: 'нет остатков', statusType: 'noStock', isAssortment: false });
                        }
                        return;
                    }

                    const currentStock = stockData.currentStock || 0;
                    const totalSales = salesByTTCode[key] || 0;
                    const daysPresent = stockData.daysPresent || 0;
                    const avgSalesPerDay = daysPresent > 0 ? totalSales / daysPresent : 0;
                    const quant = p.quant || 1;
                    const order = calcOrder(currentStock, avgSalesPerDay, period, quant);
                    const sum = order * (p.inPrice || 0);

                    if (matrixDA) {
                        // ✅ В матрице с ДА — основной заказ
                        results.push({ tt: store.tt, code, nomenclature: p.nomenclature || stockData.name || '', group: p.group || '', currentStock, sales: totalSales, daysPresent, avgSalesPerDay: parseFloat(avgSalesPerDay.toFixed(3)), order, quant, inPrice: p.inPrice || 0, sum, status: order > 0 ? `заказ ${order}` : 'достаточно', statusType: order > 0 ? 'order' : 'ok', isAssortment: false });
                    } else if (codeInMatrix && markForTT === 'НЕТ') {
                        // ⛔ Есть в матрице, но НЕТ для этой ТТ → "Не в матрице"
                        results.push({ tt: store.tt, code, nomenclature: p.nomenclature || stockData.name || '', group: p.group || '', currentStock, sales: totalSales, daysPresent, avgSalesPerDay: parseFloat(avgSalesPerDay.toFixed(3)), order, quant, inPrice: p.inPrice || 0, sum, status: order > 0 ? `Не в матрице → заказ ${order}` : 'Не в матрице', statusType: 'noMatrix', isAssortment: true });
                    } else {
                        // 📦 НЕТ в матрице вообще (код не найден) → "Вне матрицы"
                        results.push({ tt: store.tt, code, nomenclature: p.nomenclature || stockData.name || '', group: p.group || '', currentStock, sales: totalSales, daysPresent, avgSalesPerDay: parseFloat(avgSalesPerDay.toFixed(3)), order, quant, inPrice: p.inPrice || 0, sum, status: order > 0 ? `Вне матрицы → заказ ${order}` : 'Вне матрицы', statusType: 'outMatrix', isAssortment: true });
                    }
                });
            });

            // Сортировка: Вне матрицы / Не в матрице — в начало, затем по группе
            results.sort((a, b) => {
                // Вне матрицы и Не в матрицы — наверх
                if (a.isAssortment !== b.isAssortment) return a.isAssortment ? -1 : 1;
                // Вне матрицы перед Не в матрицы
                if (a.statusType === 'outMatrix' && b.statusType === 'noMatrix') return -1;
                if (a.statusType === 'noMatrix' && b.statusType === 'outMatrix') return 1;
                const gc = (a.group || '').localeCompare(b.group || '', 'ru');
                return gc !== 0 ? gc : (a.nomenclature || '').localeCompare(b.nomenclature || '', 'ru');
            });

            let filtered = results;
            if (searchResults) {
                const s = searchResults.toLowerCase();
                filtered = filtered.filter(r => r.nomenclature?.toLowerCase().includes(s) || r.code?.includes(s) || r.group?.toLowerCase().includes(s));
            }
            if (filterTT) filtered = filtered.filter(r => r.tt === filterTT);
            if (filterGroup) filtered = filtered.filter(r => r.group === filterGroup);
            if (filterStatus === 'orders') filtered = filtered.filter(r => r.order > 0);
            else if (filterStatus === 'noMatrix') filtered = filtered.filter(r => r.statusType === 'noMatrix');
            else if (filterStatus === 'outMatrix') filtered = filtered.filter(r => r.statusType === 'outMatrix');
            else if (filterStatus === 'noStock') filtered = filtered.filter(r => r.statusType === 'noStock');

            const groupedResults = {};
            filtered.forEach(r => { if (!groupedResults[r.tt]) groupedResults[r.tt] = []; groupedResults[r.tt].push(r); });
            Object.keys(groupedResults).forEach(tt => {
                groupedResults[tt].sort((a, b) => {
                    if (a.isAssortment !== b.isAssortment) return a.isAssortment ? -1 : 1;
                    if (a.statusType === 'outMatrix' && b.statusType === 'noMatrix') return -1;
                    if (a.statusType === 'noMatrix' && b.statusType === 'outMatrix') return 1;
                    const gc = (a.group || '').localeCompare(b.group || '', 'ru');
                    return gc !== 0 ? gc : (a.nomenclature || '').localeCompare(b.nomenclature || '', 'ru');
                });
            });

            const stats = { total: filtered.length, toOrder: filtered.filter(r => r.order > 0).length, noMatrix: filtered.filter(r => r.statusType === 'noMatrix').length, outMatrix: filtered.filter(r => r.statusType === 'outMatrix').length, sum: filtered.reduce((s, r) => s + r.sum, 0) };
            const allGroups = getAllGroups();

            return `<div class="space-y-3">
                <div class="bg-white rounded-lg border border-gray-200 p-3">
                    <div class="flex justify-between items-center flex-wrap gap-3">
                        <div class="flex gap-3 items-center flex-wrap">
                            <div class="flex items-center gap-2 bg-gray-50 px-3 py-2 rounded-md border">
                                <label class="text-xs text-gray-600">Период:</label>
                                <input type="number" value="${period}" onchange="period=parseInt(this.value)||21" class="input w-14 text-center" min="1" max="60">
                                <span class="text-xs text-gray-500">дней</span>
                            </div>
                            <div class="bg-sky-100 text-sky-800 rounded-md px-3 py-1.5"><div class="text-[10px] opacity-70">ПОЗИЦИЙ</div><div class="text-lg font-bold">${stats.total}</div></div>
                            <div class="bg-emerald-100 text-emerald-800 rounded-md px-3 py-1.5"><div class="text-[10px] opacity-70">К ЗАКАЗУ</div><div class="text-lg font-bold">${stats.toOrder}</div></div>
                            <div class="bg-orange-100 text-orange-800 rounded-md px-3 py-1.5"><div class="text-[10px] opacity-70">НЕ В МАТР.</div><div class="text-lg font-bold">${stats.noMatrix}</div></div>
                            <div class="bg-purple-100 text-purple-800 rounded-md px-3 py-1.5"><div class="text-[10px] opacity-70">ВНЕ МАТР.</div><div class="text-lg font-bold">${stats.outMatrix}</div></div>
                            <div class="bg-violet-100 text-violet-800 rounded-md px-3 py-1.5"><div class="text-[10px] opacity-70">СУММА</div><div class="text-lg font-bold">${stats.sum.toFixed(0)} ₽</div></div>
                        </div>
                        <div class="flex gap-2">
                            <button onclick="render()" class="btn px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-md hover:bg-green-700">Рассчитать</button>
                            <button onclick="exportOrder()" class="btn px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700">${icons.export} Экспорт</button>
                        </div>
                    </div>
                </div>
                
                <div class="bg-white rounded-lg border border-gray-200 p-3">
                    <div class="flex flex-wrap gap-2 items-center">
                        <input type="text" placeholder="Поиск..." value="${searchResults}" oninput="searchResults=this.value;render()" class="input w-40">
                        <select onchange="filterGroup=this.value;render()" class="input bg-white"><option value="">Все категории</option>${allGroups.map(g => `<option value="${g}" ${filterGroup === g ? 'selected' : ''}>${g}</option>`).join('')}</select>
                        <select onchange="filterTT=this.value;render()" class="input bg-white"><option value="">Все ТТ</option>${stores.map(s => `<option value="${s.tt}" ${filterTT === s.tt ? 'selected' : ''}>${s.tt}</option>`).join('')}</select>
                        <select onchange="filterStatus=this.value;render()" class="input bg-white">
                            <option value="">Все статусы</option>
                            <option value="orders" ${filterStatus === 'orders' ? 'selected' : ''}>С заказом</option>
                            <option value="noMatrix" ${filterStatus === 'noMatrix' ? 'selected' : ''}>Не в матрице</option>
                            <option value="outMatrix" ${filterStatus === 'outMatrix' ? 'selected' : ''}>Вне матрицы</option>
                            <option value="noStock" ${filterStatus === 'noStock' ? 'selected' : ''}>Нет остатков</option>
                        </select>
                    </div>
                </div>
                
                <div class="bg-white rounded-lg border border-gray-200 p-3">
                    <div class="table-container">
                        <table class="table-modern">
                            <thead>
                                <tr>
                                    <th class="text-left sticky left-0 bg-gray-50 z-20">Наименование</th>
                                    <th class="text-center">Код</th>
                                    <th class="text-center">Продажи</th>
                                    <th class="text-center">Дней</th>
                                    <th class="text-center">Ср./день</th>
                                    <th class="text-center">Остаток</th>
                                    <th class="text-center bg-emerald-100">Заказ</th>
                                    <th class="text-center">Статус</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${Object.entries(groupedResults).map(([tt, items]) => `
                                    <tr class="bg-amber-50 cursor-pointer hover:bg-amber-100" onclick="collapsedTT['${tt}']=!collapsedTT['${tt}'];render()">
                                        <td colspan="8" class="text-left font-semibold text-amber-800"><span class="inline-flex items-center gap-1">${collapsedTT[tt] ? icons.chevronRight : icons.chevronDown}${icons.mapPin}${tt}<span class="font-normal text-amber-600">(${items.length} поз.)</span></span></td>
                                    </tr>
                                    ${collapsedTT[tt] ? '' : items.map(r => {
                                        let rowClass = '';
                                        let statusClass = 'text-gray-500';
                                        let namePrefix = '';
                                        if (r.statusType === 'outMatrix') { rowClass = 'bg-purple-50'; statusClass = 'text-purple-700'; namePrefix = '📦 '; }
                                        else if (r.statusType === 'noMatrix') { rowClass = 'bg-orange-50'; statusClass = 'text-orange-700'; namePrefix = '⚠️ '; }
                                        else if (r.statusType === 'order') { rowClass = 'bg-emerald-50'; statusClass = 'text-emerald-600'; }
                                        else if (r.statusType === 'noStock') { rowClass = 'bg-rose-50'; statusClass = 'text-rose-600'; }
                                        return `
                                        <tr class="${rowClass} hover:bg-gray-100">
                                            <td class="sticky left-0 bg-white text-left">${namePrefix}${r.nomenclature}</td>
                                            <td class="text-center font-mono text-xs text-gray-600">${r.code}</td>
                                            <td class="text-center">${r.sales.toFixed(0)}</td>
                                            <td class="text-center text-xs text-gray-600">${r.daysPresent || '-'}</td>
                                            <td class="text-center">${r.avgSalesPerDay.toFixed(2)}</td>
                                            <td class="text-center">${r.currentStock.toFixed(2)}</td>
                                            <td class="text-center font-semibold ${r.statusType === 'outMatrix' ? 'bg-purple-100' : r.statusType === 'noMatrix' ? 'bg-orange-100' : 'bg-emerald-100'}">${r.order}</td>
                                            <td class="text-center text-xs font-medium ${statusClass}">${r.status}</td>
                                        </tr>`;
                                    }).join('')}
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>`;
        }

        // === ФАЙЛОВЫЕ ПАРСЕРЫ ===
        function handleFile(input, type) {
            const file = input.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const data = new Uint8Array(e.target.result);
                    const wb = XLSX.read(data, { type: 'array' });
                    const json = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], { header: 1, defval: '' });
                    if (type === 'sales') {
                        const { items } = SharedUtils.parseSales(json);
                        sales = items;
                        save(KEYS.SALES, sales);
                        alert(`Загружено ${sales.length} продаж`);
                    }
                    else if (type === 'stocks') {
                        const { items } = SharedUtils.parseStocks(json);
                        stocks = items;
                        save(KEYS.STOCKS, stocks);
                        alert(`Загружено ${stocks.length} остатков`);
                    }
                    render();
                } catch (err) { console.error('Parse error:', err); alert('Ошибка: ' + err.message); }
            };
            reader.readAsArrayBuffer(file);
            input.value = '';
        }

        // Парсинг ПРОДАЖ с ТТ
        function parseSalesFile(json) {
            const salesItems = [];
            let curTT = '';
            let curCategory = '';
            let curGroup = '';
            const foundTTs = new Set();

            console.log('=== Парсинг продаж с ТТ ===');

            for (let i = 0; i < json.length; i++) {
                const r = json[i];
                if (!r || r.length < 1) continue;

                const c0 = String(r[0] || '').trim();
                const c1 = String(r[1] || '').trim();
                const qty = parseFloat(String(r[4] || r[1] || '').replace(/\s/g, '').replace(',', '.')) || 0;

                if (!c0) continue;

                // Пропускаем заголовки
                if (c0.includes('В отчет выведены') || c0.includes('Валовая прибыль') ||
                    c0 === 'Склад' || c0 === 'Количество' || c0 === 'Номенклатура' ||
                    c0 === 'Параметры:' || c0 === 'Отбор:' || c0 === 'Отбор' || /^номенклатур/i.test(c0)) {
                    continue;
                }

                // Определяем ТТ по строке типа "Основной склад (КРЫМ, Бахчисарай, ул. Мира, д. 3)"
                if (c0.includes('Основной склад') || c0.includes('основной склад') || /склад.*\(.*\)/i.test(c0)) {
                    curTT = c0.trim();
                    foundTTs.add(curTT);
                    console.log('ТТ:', curTT.substring(0, 60));
                    continue;
                }

                // Категория (кат)
                if (c0.includes('(кат)')) {
                    curCategory = c0.replace(/\s*\(кат.*\)/i, '').replace(/\s*\(шт\)/i, '').replace(/\s*\(кг\)/i, '').trim();
                    curGroup = '';
                    continue;
                }

                // Группа (гр)
                if (c0.includes('(гр)')) {
                    curGroup = c0.replace(/\s*\(гр.*\)/i, '').replace(/\s*\(шт\)/i, '').replace(/\s*\(кг\)/i, '').trim();
                    continue;
                }

                // Товар с продажами
                if (qty > 0 && c0.length > 3 && curTT) {
                    const group = curGroup || curCategory || '';
                    salesItems.push({ tt: curTT, name: c0, quantity: qty, group });
                }
            }

            sales = salesItems;
            save(KEYS.SALES, sales);
            console.log(`Продаж: ${salesItems.length}, ТТ: ${foundTTs.size}`);
            alert(`Загружено ${salesItems.length} продаж\nТТ: ${foundTTs.size}`);
        }

        // Парсинг ОСТАТКОВ
        function parseStocksFile(json) {
            let lastCol = 0;
            for (let i = 0; i < json.length; i++) if (json[i]) lastCol = Math.max(lastCol, json[i].length - 1);

            const stockItems = [];
            const foundTTs = new Set();
            let curTT = '';

            console.log('=== Парсинг остатков ===');

            for (let i = 3; i < json.length; i++) {
                const r = json[i];
                if (!r || r.length < 3) continue;
                
                const c0 = String(r[0] || '').trim();
                const code = String(r[1] || '').trim();
                
                const isTT = /склад|магазин|основной/i.test(c0) && !/^\d/.test(code);
                const isProductCode = /^\d/.test(code) || code.length >= 5;
                
                if (isTT) {
                    curTT = c0;
                    foundTTs.add(curTT);
                } else if (isProductCode && curTT && c0) {
                    const normC = normCode(code);
                    const currentStock = parseFloat(String(r[lastCol])) || 0;
                    
                    let daysPresent = 0, totalDays = 0;
                    for (let col = 2; col <= lastCol; col++) {
                        const val = r[col];
                        if (val !== undefined && val !== null && val !== '') {
                            totalDays++;
                            if ((parseFloat(String(val)) || 0) > 0) daysPresent++;
                        }
                    }
                    
                    stockItems.push({ tt: curTT, code: normC, name: c0, currentStock, daysPresent, totalDays });
                    
                    if (!matrix[normC]) {
                        matrix[normC] = { nomenclature: c0, code: normC, group: '', packaging: 'ШТ', inPrice: 0, quant: 1 };
                    } else if (!matrix[normC].nomenclature) {
                        matrix[normC].nomenclature = c0;
                    }
                    // Не устанавливаем ДА/НЕТ из остатков — это делает матрица
                }
            }

            stocks = stockItems;
            save(KEYS.STOCKS, stocks);
            save(KEYS.ASSORTMENT, matrix);
            console.log(`Остатков: ${stockItems.length}, ТТ: ${foundTTs.size}`);
            alert(`Загружено ${stockItems.length} остатков\nТТ: ${foundTTs.size}`);
        }

        function exportOrder() {
            if (stores.length === 0) { alert('Нет данных'); return; }
            
            const stockMap = new Map();
            stocks.forEach(s => stockMap.set(`${s.tt}_${s.code}`, s));

            const salesByTTCode = {};
            sales.forEach(s => {
                const product = Object.values(matrix).find(p => p.nomenclature === s.name);
                if (product && s.tt) {
                    const key = `${s.tt}_${product.code}`;
                    salesByTTCode[key] = (salesByTTCode[key] || 0) + s.quantity;
                }
            });
            
            const rows = [['ТТ', 'Код', 'Наименование', 'Группа', 'Продажи', 'Дней', 'Ср./день', 'Остаток', 'Заказ', 'Сумма', 'Статус']];
            
            stores.forEach(store => {
                Object.entries(matrix).forEach(([code, p]) => {
                    const key = `${store.tt}_${code}`;
                    const stockData = stockMap.get(key);
                    const codeInMatrix = !!matrixMarks[code];
                    const markForTT = codeInMatrix ? (matrixMarks[code][store.tt] || 'НЕТ') : null;
                    const matrixDA = markForTT === 'ДА';

                    if (!matrixDA && !stockData) return;
                    if (!stockData) { rows.push([store.tt, code, p.nomenclature || '', p.group || '', salesByTTCode[key] || 0, 0, 0, 0, 0, 0, 'нет остатков']); return; }

                    const currentStock = stockData.currentStock || 0;
                    const daysPresent = stockData.daysPresent || 0;
                    const totalSales = salesByTTCode[key] || 0;
                    const avgSalesPerDay = daysPresent > 0 ? totalSales / daysPresent : 0;
                    const quant = p.quant || 1;
                    const order = calcOrder(currentStock, avgSalesPerDay, period, quant);

                    let status;
                    if (matrixDA) {
                        status = order > 0 ? 'заказ' : 'достаточно';
                    } else if (codeInMatrix && markForTT === 'НЕТ') {
                        status = 'Не в матрице';
                    } else {
                        status = 'Вне матрицы';
                    }

                    rows.push([store.tt, code, p.nomenclature || '', p.group || '', totalSales.toFixed(0), daysPresent, avgSalesPerDay.toFixed(3), currentStock.toFixed(2), order, (order * (p.inPrice || 0)).toFixed(2), status]);
                });
            });
            
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(rows), 'Заказ');
            XLSX.writeFile(wb, 'order.xlsx');
        }

        function clearAll() {
            [KEYS.ASSORTMENT, KEYS.MATRIX_MARKS, KEYS.SALES, KEYS.STOCKS, KEYS.GROUP_MARKUPS].forEach(k => localStorage.removeItem(k));
            matrix = {}; matrixMarks = {}; sales = []; stocks = []; groupMarkups = {};
            render();
            alert('Данные очищены');
        }



        // Инициализируем сразу с локальными данными
        try { init(); } catch(e) { console.error('Init error:', e); document.getElementById('content').innerHTML = '<div class="p-4 text-red-600">Ошибка инициализации: ' + e.message + '</div>'; }

        // После загрузки из облака — перечитываем данные и перерисовываем
        window.addEventListener('cloudStorageReady', () => {
            loadStoresFromHTML();
            const savedAssort = load(KEYS.ASSORTMENT, null);
            const savedMarks = load(KEYS.MATRIX_MARKS, null);
            if (savedAssort !== null) matrix = savedAssort;
            if (savedMarks !== null) matrixMarks = savedMarks;
            sales = load(KEYS.SALES, []);
            stocks = load(KEYS.STOCKS, []);
            defaultMarkup = load(KEYS.DEFAULT_MARKUP, 25);
            groupMarkups = load(KEYS.GROUP_MARKUPS, {});
            render();
        });
    </script>
</body>
</html>